legacy-peer-deps=true
# Flatten node_modules (like npm/yarn). Required for Expo / React Native native
# builds (CocoaPods + RN scripts) which cannot resolve pnpm's isolated symlinked
# layout — that broke `pod install` (set_RCTNewArchEnabled_in_info_plist) and
# Xcode "Build input files cannot be found" for hashed .pnpm paths.
node-linker=hoisted
# Stable hoisting so native module paths don't change between installs.
shamefully-hoist=true
